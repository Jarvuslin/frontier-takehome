# Safco Catalog Agent — environment variables
# Copy to .env. Project runs end-to-end with no values set; only LLM fallback needs a key.

# --- LLM fallback (optional, off by default) -----------------------
# When enabled, products with missing critical fields (name/sku/price)
# are sent to Claude Haiku 4.5 for structured extraction. Costs ~$0.001/page.
LLM_FALLBACK_ENABLED=false
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# --- Crawl tuning (overrides config/crawler.yaml) ------------------
# SAFCO_RATE_LIMIT_RPS=1.0
# SAFCO_MAX_PRODUCTS_PER_CATEGORY=50
# SAFCO_USER_AGENT=SafcoCatalogBot/0.1 (+evaluation prototype)

# --- Logging -------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json   # json | console
